# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
HTTPS_PORT=3443

# ─── TLS / HTTPS ──────────────────────────────────────────────────────────────
# Paths to your SSL certificate and private key (PEM format).
# Generate self-signed certs with: bash scripts/generate-certs.sh
CERT_PATH=./certs/cert.pem
KEY_PATH=./certs/key.pem

# ─── AI / Agent Configuration ─────────────────────────────────────────────────
# OpenAI-compatible API key (OpenAI, Azure OpenAI, LocalAI, Ollama-compatible, etc.)
#AI_API_KEY=sk-your-openai-key-here
# Base URL – change for alternative providers
#AI_BASE_URL=https://api.openai.com/v1
# Model to use for the Coder and Planner agents
#AI_MODEL=gpt-4o
# Optional: separate review model (falls back to AI_MODEL if not set)
#AI_REVIEW_MODEL=

# Google Gemini API (OpenAI-compatible)
AI_API_KEY=your_api
AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/v1/beta/
AI_MODEL=gemini-1.5-flash

# ─── Authentication ───────────────────────────────────────────────────────────
# Strong random string for JWT signing (generate: openssl rand -hex 32)
AUTH_SECRET=change_this_to_a_secure_random_string_min_32_chars
# Default admin credentials (change immediately in production!)
ADMIN_USER=admin
ADMIN_PASS=changeme
# JWT expiry
JWT_EXPIRES_IN=24h

# ─── Storage ──────────────────────────────────────────────────────────────────
# Directory where all project site files are stored
SITE_DIR=./site
